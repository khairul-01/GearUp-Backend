
model User {
    id        String   @id @default(uuid())
    name    String  @db.VarChar(255)
    email   String @unique
    password String
    phone String?
    profileImage String?
    role UserRole
    status UserStatus   @default(ACTIVE)
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    gearItems GearItem[]

    rentals RentalOrder[]

    reviews Review[]

    @@map("users")
}